<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root_overlay"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#CC111111"
    android:clickable="true"
    android:focusable="true"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:paddingTop="14dp"
    android:paddingBottom="14dp">

    <TextView
        android:id="@+id/tv_pickup_address"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="—"
        android:textSize="15sp"
        android:textStyle="bold"
        android:textColor="@color/pin_pickup"
        android:maxLines="2"
        android:ellipsize="end" />

    <TextView
        android:id="@+id/tv_dropoff_address"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="—"
        android:textSize="15sp"
        android:textStyle="bold"
        android:textColor="@color/pin_dropoff"
        android:maxLines="2"
        android:ellipsize="end" />

    <Button
        android:id="@+id/btn_open_maps"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Open in Google Maps"
        android:backgroundTint="#4285F4"
        android:textColor="#FFFFFF"
        android:textStyle="bold" />

</LinearLayout>
