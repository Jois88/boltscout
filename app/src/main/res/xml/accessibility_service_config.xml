<?xml version="1.0" encoding="utf-8"?>
<!--
    AccessibilityService configuration.
    Monitors the Bolt driver app (ee.mtakso.client) for ride request screens.
    canRetrieveWindowContent = true allows reading text from Bolt's UI nodes.
-->
<accessibility-service xmlns:android="http://schemas.android.com/apk/res/android"
    android:accessibilityEventTypes="typeWindowStateChanged|typeWindowContentChanged"
    android:accessibilityFeedbackType="feedbackGeneric"
    android:accessibilityFlags="flagReportViewIds|flagRetrieveInteractiveWindows|flagRequestFilterKeyEvents"
    android:canRetrieveWindowContent="true"
    android:description="@string/accessibility_service_description"
    android:notificationTimeout="100"
    android:packageNames="ee.mtakso.driver,com.bolt.driver,taxi.android.client" />
